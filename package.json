{
  "name": "hhe-directory",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "docs:routes": "tsx scripts/generate-routes-index.ts",
    "docs:routes:check": "tsx scripts/generate-routes-index.ts --check",
    "prebuild": "tsx scripts/generate-routes-index.ts",
    "build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "typesense:bootstrap": "tsx --env-file=.env scripts/typesense-bootstrap.ts",
    "typesense:reset": "tsx --env-file=.env scripts/typesense-reset.ts",
    "typesense:reindex": "tsx --env-file=.env scripts/typesense-index.ts",
    "typesense:synonyms": "tsx --env-file=.env scripts/typesense-synonyms-sync.ts",
    "taxonomy:seed": "tsx --env-file=.env scripts/seed-taxonomy.ts",
    "import:pilot": "tsx --env-file=.env scripts/import-pilot-practitioners.ts",
    "photos:wire": "tsx --env-file=.env scripts/wire-pilot-photos.ts",
    "photos:backfill": "tsx --env-file=.env scripts/backfill-pilot-photos.ts",
    "probe:search": "tsx --env-file=.env scripts/probe-search-uptime.ts",
    "postinstall": "prisma generate",
    "taglines:backfill": "tsx --env-file=.env scripts/backfill-taglines.ts",
    "links:audit": "tsx --env-file=.env scripts/audit-profile-links.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.5.0",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.53.1",
    "@upstash/ratelimit": "^2.0.8",
    "@vercel/blob": "^2.4.0",
    "@vercel/functions": "^3.6.0",
    "@vercel/kv": "^3.0.0",
    "@whop/api": "^0.0.51",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "lucide-react": "^0.469.0",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.25",
    "react": "^18",
    "react-dom": "^18",
    "react-instantsearch": "^7.33.0",
    "react-instantsearch-nextjs": "^1.2.4",
    "resend": "^4.8.0",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "typesense": "^3.0.6",
    "typesense-instantsearch-adapter": "^2.9.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.21",
    "postcss": "^8",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
