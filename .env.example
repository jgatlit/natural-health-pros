# HHE Directory — environment variables
# Copy to .env.local for development; provision via Vercel env for deploy.

# ----- Postgres (Neon via Vercel Marketplace integration) -----
DATABASE_URL=

# ----- NextAuth v5 -----
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ----- Upstash / Vercel KV (rate limiting; optional in Phase 0) -----
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ----- Typesense (Phase 1 search) -----
TYPESENSE_HOST=
TYPESENSE_API_KEY=
NEXT_PUBLIC_TYPESENSE_SEARCH_KEY=

# ----- Email (Resend; Phase 2 notifications) -----
RESEND_API_KEY=

# ----- Vercel Blob (Phase 3 client-held files) -----
BLOB_READ_WRITE_TOKEN=
