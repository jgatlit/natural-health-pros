// HHE Directory — Phase 0 schema
// HHE-students-first practitioner directory (post-5/15 clean restart)
// Brand: HHE Directory (supersedes "PracticeNear" name discontinued 2026-05-24)
// See STRATEGIC_RECONCILIATION_2026-05-18 + decisions-JSON Phase 1 YES rows

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Neon Marketplace integration prefixes all env vars with `hhe_directory_` by default.
  // If the prefix is later removed in Vercel/Neon settings, rename to standard names.
  url       = env("hhe_directory_DATABASE_URL") // pooled (pgbouncer) — runtime queries
  directUrl = env("hhe_directory_DATABASE_URL_UNPOOLED") // unpooled — Prisma Migrate (DDL needs direct connection)
}

// ----- NextAuth v5 tables (Prisma adapter contract) -----

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  practitioner        Practitioner?
  invitationsSent     Invitation[]  @relation("InvitedBy")
  invitationsAccepted Invitation[]  @relation("AcceptedBy")
}

enum Role {
  CLIENT
  PRACTITIONER
  ADMIN
}

// Wedge 2C — Whop Platforms KYC lifecycle (sub-merchant company verification)
enum WhopKycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

// Wedge 2C — WhopProduct interval semantics
enum ProductInterval {
  ONE_TIME
  MONTHLY
  ANNUAL
}

// Layer X — practitioner platform-subscription lifecycle (they pay us to be listed)
enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ----- HHE Directory Phase 0 domain -----

model Practitioner {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug        String  @unique
  displayName String
  bio         String? @db.Text

  // V1 pilot — rich landing-page fields (Amy 5/28; LLM-onboarding normalizes these)
  headline               String? // credentials / professional title line under the name
  tagline                String? // short hook above the whoIHelp paragraph; extractive-only (compressed from the practitioner's own words, never an invented claim). Optional — NOT a completeness signal.
  whoIHelp               String?  @db.Text // "who/how I help" block + matching signal (LLM-synthesized when source blank)
  photoUrl               String? // Vercel Blob URL; Avatar falls back to initials when null
  websiteUrl             String? // external site (classified out of overloaded col-D)
  telehealth             Boolean? // offers virtual sessions (~70% of pilot)
  inPerson               Boolean? // offers in-person sessions
  firstSessionPriceCents Int? // first-session price in cents; render as $X.XX
  hheCertified           Boolean  @default(true) // HHE-certification trust badge (pilots are HHE grads)

  cityId      String?
  city        City?                   @relation(fields: [cityId], references: [id])
  specialties PractitionerSpecialty[]
  caseStudies CaseStudy[]

  latitude  Float?
  longitude Float?

  // Denormalized for pg_trgm typo tolerance (Decisions-JSON Phase 1)
  searchText String? @db.Text

  // Range-facetable attribute (Phase 1 stretch)
  yearsInPractice Int?

  // Wedge 2B — practitioner-owned booking links (Cal.com / Calendly / etc.)
  // Multi-tenant by construction: each practitioner brings their own scheduling provider.
  // Multiple links supported (e.g. "Free intro" + "Deep dive"); see BookingLink.
  bookingLinks BookingLink[]
  // DEPRECATED: superseded by bookingLinks. Kept for expand/contract zero-downtime
  // migration on the shared Neon DB; data copied into BookingLink. Drop in a follow-up.
  bookingUrl   String?

  // Wedge 2C — Whop Platforms sub-merchant (Connected Account)
  // whopCompanyId is the practitioner's sub-merchant company on HHE's Whop platform parent.
  // KYC + payouts handled by Whop; HHE collects an application_fee per checkout (see WhopProduct).
  whopCompanyId      String?       @unique
  whopKycStatus      WhopKycStatus @default(NOT_STARTED)
  whopKycCompletedAt DateTime?
  whopProducts       WhopProduct[]

  // Layer X — platform subscription (practitioner pays $59/mo to be listed; pilots trial for 90 days)
  subscriptionStatus SubscriptionStatus @default(NONE)
  /// DEPRECATED — superseded by trialEndsAt + the ADMIN exemption (see
  /// docs/superpowers/specs/2026-07-16-pilot-trial-design.md). No longer read by isListed().
  /// Column retained one release so the live deployment does not break the moment the
  /// migration applies (expand/contract); drop it in a follow-up once nothing reads it.
  comped             Boolean            @default(false)
  /// 90-day pilot clock. null = pre-trial (operator-seeded, never onboarded) and still listed;
  /// future = trial running; past = expired. Set ONLY by genuine onboarding — never inferred
  /// from a seed date. Admins are exempt from it entirely.
  trialEndsAt        DateTime?
  whopMembershipId   String?            @unique // membership on our own $59/mo Whop product

  // Invite-only model (5/15 Amy reframe)
  invitedBy  String?
  invitedAt  DateTime?
  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([latitude, longitude]) // haversine "near me"
}

model BookingLink {
  id             String       @id @default(cuid())
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  label          String? // optional title, e.g. "Free 15-min intro"
  url            String
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([practitionerId])
}

// V1 pilot — evolving dual-label taxonomy (Amy 5/29 "collapse synonyms" requirement).
// Canonical node: faceted + matched on. rawLabel (on PractitionerSpecialty) preserves voice.
enum SpecialtyStatus {
  ACTIVE // curated, live canonical
  PROPOSED // promoted from a pending alias, awaiting parent/curation
  MERGED // collapsed into mergedInto; kept for referential history
}

model Specialty {
  id       String      @id @default(cuid())
  slug     String      @unique
  name     String
  parentId String? // hierarchical taxonomy
  parent   Specialty?  @relation("SpecialtyTree", fields: [parentId], references: [id])
  children Specialty[] @relation("SpecialtyTree")

  status       SpecialtyStatus @default(ACTIVE)
  mergedIntoId String? // when MERGED, points at the surviving canonical
  mergedInto   Specialty?      @relation("SpecialtyMerge", fields: [mergedIntoId], references: [id])
  mergedFrom   Specialty[]     @relation("SpecialtyMerge")

  aliases       SpecialtyAlias[]
  practitioners PractitionerSpecialty[]
}

// Bridge between a practitioner's raw phrasing and the system canonical.
// PENDING rows are the /admin/specialties moderation queue. APPROVED rows
// sync to Typesense as multi-way synonyms (the "gut health ⇄ digestive disorders" collapse).
enum AliasSource {
  PRACTITIONER // self-entered during intake
  CURATED // operator-authored
  IMPORT // seeded by the onboarding LLM pipeline
}

enum AliasStatus {
  PENDING
  APPROVED
  REJECTED
}

model SpecialtyAlias {
  id          String      @id @default(cuid())
  label       String      @unique // normalized (lowercased, trimmed) raw phrasing
  specialtyId String
  specialty   Specialty   @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  source      AliasSource @default(PRACTITIONER)
  status      AliasStatus @default(PENDING)
  confidence  Float? // 0..1 from LLM/vector mapping; null for curated
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([specialtyId])
}

model PractitionerSpecialty {
  practitionerId String
  specialtyId    String
  rawLabel       String? // the practitioner's exact phrasing (their voice), shown on profile
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  specialty      Specialty    @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([practitionerId, specialtyId])
}

// V1 pilot — anonymized outcomes the AI matcher reads (Amy: "if it's not on the
// landing page, it's not going to come up in search"). Backend matching signal +
// optional landing-page block.
model CaseStudy {
  id             String       @id @default(cuid())
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  title          String
  summary        String       @db.Text
  outcome        String?      @db.Text
  anonymized     Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@index([practitionerId])
}

// Wedge 2C — Whop product (offering) attached to a practitioner's sub-merchant company
model WhopProduct {
  id             String       @id @default(cuid())
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  whopProductId        String? @unique // products.create response (null until Layer Y wires Whop)
  whopPlanId           String? // plans.create response
  whopCheckoutConfigId String? // checkoutConfigurations.create response
  purchaseUrl          String? // Whop-hosted checkout URL

  title               String
  description         String?
  priceUsdCents       Int // always in cents; render as $X.XX
  applicationFeeCents Int             @default(0) // HHE platform fee per transaction
  interval            ProductInterval @default(ONE_TIME)
  category            String? // offering type label: consultation, product, package, subscription…

  active    Boolean  @default(true)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([practitionerId, active])
}

// Wedge 2C — webhook event log (dedup + audit + retry surface)
model WhopWebhookEvent {
  id          String    @id @default(cuid())
  whopEventId String    @unique
  eventType   String
  payload     Json
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  error       String?

  @@index([eventType, processedAt])
}

// Wedge 2A — practitioner invitation system
model Invitation {
  id               String    @id @default(cuid())
  token            String    @unique
  email            String
  invitedById      String?
  invitedBy        User?     @relation("InvitedBy", fields: [invitedById], references: [id])
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  /// Relation added so /admin/invites can reach the practitioner behind an accepted invite
  /// (for the Reset-trial action). Previously a bare String with no relation.
  acceptedByUser   User?     @relation("AcceptedBy", fields: [acceptedByUserId], references: [id])
  createdAt        DateTime  @default(now())

  @@index([email])
  @@index([acceptedAt])
}

model City {
  id            String         @id @default(cuid())
  slug          String
  name          String
  state         String
  practitioners Practitioner[]

  @@unique([slug, state])
}
